---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const cases = await getCollection("cases", ({ data }) => data.status !== "draft");
  return cases.map((c) => ({ params: { slug: c.id }, props: { entry: c } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="case-detail">
    <header class="case-header">
      <p class="eyebrow">{entry.data.domain}</p>
      <h1>{entry.data.title}</h1>
      <p class="case-header__summary">{entry.data.summary}</p>
      <div class="case-header__meta">
        <time datetime={entry.data.date.toISOString().slice(0, 10)}>
          {entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <span class={`outcome-badge outcome-badge--${entry.data.outcome}`}>{entry.data.outcome}</span>
        {entry.data.author && <span class="case-header__author">by {entry.data.author}</span>}
      </div>
      <ul class="case-header__tags">
        {entry.data.tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    </header>

    <div class="case-body prose">
      <Content />
    </div>

    {entry.data.timeline.length > 0 && (
      <section class="timeline" aria-label="Decision timeline">
        <h2>Timeline</h2>
        <ol class="timeline__list">
          {entry.data.timeline.map((event) => (
            <li class="timeline__event">
              <span class="timeline__date">{event.date}</span>
              <strong class="timeline__label">{event.label}</strong>
              {event.description && <p class="timeline__desc">{event.description}</p>}
            </li>
          ))}
        </ol>
      </section>
    )}

    {entry.data.artifacts.length > 0 && (
      <section class="artifacts" aria-label="Artifacts">
        <h2>Artifacts</h2>
        {entry.data.artifacts.map((artifact) => (
          <figure class="artifact">
            <img src={artifact.src} alt={artifact.alt} loading="lazy" />
            {artifact.caption && <figcaption>{artifact.caption}</figcaption>}
          </figure>
        ))}
      </section>
    )}

    <footer class="case-footer">
      <a href="/">&larr; Back to archive</a>
    </footer>
  </article>
</BaseLayout>
